{
  "expo": {
    "name": "StreamDeck Remote",
    "slug": "streamdeck-remote",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/128x128@2x.png",
    "scheme": "streamdeckremote",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-dev-client"
    ],
    "splash": {
      "image": "./assets/128x128@2x.png",
      "resizeMode": "contain",
      "backgroundColor": "#101214"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "StreamDeck Remote connects to your Stream Deck desktop app on your local network."
      }
    },
    "android": {
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_ADVERTISE",
        "BLUETOOTH_CONNECT",
        "CHANGE_WIFI_MULTICAST_STATE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/128x128@2x.png",
        "backgroundColor": "#101214"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.antonis_ge0.streamdeckremote"
    },
    "web": {
      "favicon": "./assets/128x128@2x.png"
    },
    "extra": {
      "eas": {
        "projectId": "bf32af4a-afca-4463-b6a6-ae6e0daf191e"
      }
    }
  }
}
